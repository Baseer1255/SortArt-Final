{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Next.js: dev server",
      "type": "node-terminal",
      "request": "launch",
      "command": "npm run dev",
      "cwd": "${workspaceFolder}"
    },
    {
      "name": "Next.js: Chrome (client)",
      "type": "chrome",
      "request": "launch",
      "url": "http://localhost:3000",
      "webRoot": "${workspaceFolder}/Sortart"
    }
  ],
  "compounds": [
    {
      "name": "Next.js: dev + Chrome",
      "configurations": ["Next.js: dev server", "Next.js: Chrome (client)"],
      "stopAll": true,
      "presentation": {
        "hidden": false,
        "group": "sortart",
        "order": 1
      }
    }
  ]
}
